{
	"name": "drago-ex/project-backend",
	"type": "drago-project-resource",
	"description": "Preconfigured basic backend module for the basic Drago Project.",
	"license": ["MIT"],
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/application": "^2.0",
		"drago-ex/translator": "^3.0",
		"drago-ex/project-front": "^2.0"
	},
	"extra": {
		"drago-project": {
			"install": {
				"copy": {
					"resources/app": "app",
					"resources/assets": "assets"
				}
			},
			"commands": {
				"create:backend-permission": "php vendor/bin/create-backend-permission"
			}
		}
	},
	"require-dev": {
		"phpstan/phpstan-nette": "^2.0",
		"drago-ex/project-installer": "@dev"
	},
	"bin": [
		"bin/create-backend-permission"
	],
	"scripts": {
		"phpstan": "phpstan analyse",
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
