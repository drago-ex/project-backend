{
	"name": "drago-ex/project-backend",
	"type": "drago-tools-resource",
	"description": "Preconfigured basic backend module for the basic Drago Project.",
	"license": ["MIT"],
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/application": "^2.0",
		"drago-ex/project-front": "^2.0"
	},
	"suggest": {
		"drago-ex/translator": "Configures Latte translation support for bundled templates using translation macros."
	},
	"extra": {
		"drago-tools": {
			"install": {
				"copy": {
					"resources/app": "app",
					"resources/assets": "assets"
				}
			},
			"commands": {
				"create:backend-permission": "php vendor/bin/create-permission"
			}
		}
	},
	"require-dev": {
		"phpstan/phpstan-nette": "^2.0",
		"drago-ex/project-tools": "^1.0"
	},
	"bin": [
		"bin/create-permission"
	],
	"scripts": {
		"phpstan": "phpstan analyse",
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
