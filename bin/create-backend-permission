#!/usr/bin/env php
<?php

declare(strict_types=1);

$dir = __DIR__;
$generator = null;

while (true) {
	$candidate = $dir . '/vendor/drago-ex/permission/bin/create-permission';
	if (is_file($candidate)) {
		$generator = $candidate;
		break;
	}

	$parent = dirname($dir);
	if ($parent === $dir) {
		break;
	}
	$dir = $parent;
}

if ($generator === null) {
	fwrite(STDERR, "ERR Generator not found.\n");
	fwrite(STDERR, "ERR Install dependency first: composer require drago-ex/permission\n");
	exit(1);
}

$args = [
	'AdminPermission',
	'App\\UI\\Backend\\Admin',
	'Backend:Admin',
	'app/UI/Backend/Admin',
	'--allow=RoleAdmin',
];

$command = 'php ' . escapeshellarg($generator);
foreach ($args as $arg) {
	$command .= ' ' . escapeshellarg($arg);
}

passthru($command, $exitCode);
exit((int) $exitCode)
