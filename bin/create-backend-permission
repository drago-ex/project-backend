#!/usr/bin/env php
<?php

declare(strict_types=1);

$dir = __DIR__;
$generator = null;

while (true) {
	$candidate = $dir . '/vendor/drago-ex/permission/bin/create-permission';
	if (is_file($candidate)) {
		$generator = $candidate;
		break;
	}

	$parent = dirname($dir);
	if ($parent === $dir) {
		break;
	}
	$dir = $parent;
}

if ($generator === null) {
	fwrite(STDERR, "Generator not found.\n");
	fwrite(STDERR, "Install dependency first: composer require drago-ex/permission\n");
	exit(1);
}

$positionalArgs = [
	'className'   => 'PermissionProvider',
	'namespace'   => 'App\\Presentation\\Backend\\Admin',
	'resource'    => 'Backend:Admin',
	'outputDir'   => 'app/Presentation/Backend/Admin',
];

$options = [
	'--allow=RoleAdmin',
];

$args = array_merge(array_values($positionalArgs), $options);

$command = 'php ' . escapeshellarg($generator);
foreach ($args as $arg) {
	$command .= ' ' . escapeshellarg($arg);
}

passthru($command, $exitCode);
exit((int) $exitCode);
